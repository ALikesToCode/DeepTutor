# ============================================
# DeepTutor Environment Template
# ============================================
# Copy this file to `.env` and fill in your values.
# Core runtime settings are grouped as:
# ports / llm / embedding / search / docker-cloud / security

# --------------------------------------------
# Ports
# --------------------------------------------
BACKEND_PORT=8001
FRONTEND_PORT=3782

# --------------------------------------------
# LLM (Required)
# --------------------------------------------
# Supported bindings: openai, navy, lm_studio, ollama, azure_openai, deepseek, ...
# For a full list run: deeptutor provider list // README
LLM_BINDING=navy
LLM_MODEL=gpt-5.4-mini
# Leave blank when using NavyAI; DeepTutor will use NAVY_API_KEY below.
LLM_API_KEY=
LLM_HOST=https://api.navy/v1
LLM_API_VERSION=

# --------------------------------------------
# Embedding (Required for knowledge base features)
# --------------------------------------------
# NavyAI exposes Gemini embeddings through its OpenAI-compatible `/v1/embeddings`.
EMBEDDING_BINDING=navy
EMBEDDING_MODEL=gemini-embedding-2-preview
# Leave blank when using NavyAI; DeepTutor will use NAVY_API_KEY below.
EMBEDDING_API_KEY=
EMBEDDING_HOST=https://api.navy/v1
EMBEDDING_DIMENSION=3072
EMBEDDING_API_VERSION=
# Whether to send the `dimensions` request parameter to the embedding endpoint.
#   true   -> always send  (only OpenAI text-embedding-3* officially supports it)
#   false  -> never send   (set this for Qwen text-embedding-v4 and other providers
#                          that return HTTP 400 when `dimensions` is present)
#   <empty> or unset -> auto: send only for OpenAI text-embedding-3* family
EMBEDDING_SEND_DIMENSIONS=false

# --------------------------------------------
# NavyAI all-in-one API key + media generation
# --------------------------------------------
# Fill this single key for chat, embeddings, image/video generation, and other
# NavyAI OpenAI-compatible services.
NAVY_API_KEY=
NAVY_API_BASE=https://api.navy/v1
NAVY_IMAGE_MODEL=gpt-image-2
NAVY_VIDEO_MODEL=grok-imagine-video

# ⚠️  Docker + local LLM (LM Studio / Ollama / vLLM)
# ─────────────────────────────────────────────────────
# When running DeepTutor in Docker and your LLM runs on the HOST machine:
#   - Do NOT use "localhost" or "127.0.0.1" — inside the container these
#     refer to the container itself, not the host.
#   - macOS / Windows Docker Desktop: use http://host.docker.internal:<port>/v1
#   - Linux: use the host's LAN IP, e.g. http://192.168.1.100:<port>/v1
#     (or run Docker with --network=host)
#
# Example (LM Studio on port 1234):
#   LLM_BINDING=lm_studio
#   LLM_HOST=http://host.docker.internal:1234/v1
#   EMBEDDING_BINDING=lm_studio
#   EMBEDDING_HOST=http://host.docker.internal:1234/v1

# --------------------------------------------
# Web Search (Optional)
# --------------------------------------------
SEARCH_PROVIDER=
SEARCH_API_KEY=
SEARCH_BASE_URL=

# --------------------------------------------
# Docker / Cloud deployment (Optional)
# --------------------------------------------
# Public backend URL used by the frontend when deployed remotely.
# Use `same-origin` when a reverse proxy or Cloudflare Worker routes `/api/*`
# to the backend on the same public origin as the frontend.
NEXT_PUBLIC_API_BASE_EXTERNAL=
# Alternative direct API base URL.
NEXT_PUBLIC_API_BASE=

# --------------------------------------------
# Security / Networking (Optional)
# --------------------------------------------
# Set DEEPTUTOR_AUTH_PASSWORD to enable the web login page.
# Leave it blank for local open access. In production, set this as a secret.
DEEPTUTOR_AUTH_PASSWORD=
# Optional separate signing secret. Use a long random value in production.
DEEPTUTOR_AUTH_SECRET=
# Optional override: false disables the login gate even when a password exists.
DEEPTUTOR_AUTH_ENABLED=
DEEPTUTOR_AUTH_MAX_AGE_SECONDS=604800

# Keep this false in production.
DISABLE_SSL_VERIFY=false
