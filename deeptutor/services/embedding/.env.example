# ============================================
# EMBEDDING SERVICE CONFIGURATION EXAMPLES
# ============================================
# Copy the relevant section to your .env file

# ============================================
# OPTION 1: NavyAI (Cloud - all-in-one)
# ============================================
# Best for: Production with one API key for chat, embeddings, and media
# Cost: Pay-per-use
NAVY_API_KEY=sk-your-navy-api-key-here
EMBEDDING_BINDING=navy
EMBEDDING_MODEL=gemini-embedding-2-preview
EMBEDDING_DIMENSION=3072
EMBEDDING_API_KEY=
EMBEDDING_HOST=https://api.navy/v1
EMBEDDING_SEND_DIMENSIONS=false
EMBEDDING_REQUEST_TIMEOUT=30
EMBEDDING_TRUNCATE=true

# ============================================
# OPTION 2: OpenAI (Cloud - Commercial)
# ============================================
# Best for: Production, high quality, state-of-the-art
# Cost: Pay-per-use
EMBEDDING_BINDING=openai
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSION=3072
EMBEDDING_API_KEY=sk-your-openai-api-key-here
EMBEDDING_HOST=https://api.openai.com/v1
EMBEDDING_REQUEST_TIMEOUT=30
EMBEDDING_TRUNCATE=true

# ============================================
# OPTION 3: Ollama (Local - Open Source) ⭐
# ============================================
# Best for: Development, privacy, zero cost
# Requirements: Ollama installed locally
# Install: https://ollama.ai
# Download model: ollama pull nomic-embed-text

EMBEDDING_BINDING=ollama
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSION=768
EMBEDDING_HOST=http://localhost:11434
EMBEDDING_REQUEST_TIMEOUT=30
# No API key needed for Ollama!

# Other Ollama model options:
# EMBEDDING_MODEL=all-minilm              # 384 dimensions, fast
# EMBEDDING_MODEL=all-mpnet-base-v2       # 768 dimensions, balanced
# EMBEDDING_MODEL=mxbai-embed-large       # 1024 dimensions, best quality
# EMBEDDING_MODEL=snowflake-arctic-embed  # 1024 dimensions, good performance

# ============================================
# OPTION 4: Cohere (Cloud - Commercial)
# ============================================
# Best for: Multilingual, task-aware embeddings
# Cost: Pay-per-use
EMBEDDING_BINDING=cohere
EMBEDDING_MODEL=embed-v4.0
EMBEDDING_DIMENSION=1024
EMBEDDING_API_KEY=your-cohere-api-key-here
EMBEDDING_HOST=https://api.cohere.ai
EMBEDDING_INPUT_TYPE=search_document
EMBEDDING_REQUEST_TIMEOUT=30
EMBEDDING_TRUNCATE=true

# Input type options for Cohere:
# EMBEDDING_INPUT_TYPE=search_document  # For documents to index
# EMBEDDING_INPUT_TYPE=search_query     # For search queries
# EMBEDDING_INPUT_TYPE=classification   # For classification tasks
# EMBEDDING_INPUT_TYPE=clustering       # For clustering

# Cohere model options:
# EMBEDDING_MODEL=embed-v4.0                    # Latest, 256-1536 dims
# EMBEDDING_MODEL=embed-english-v3.0            # English only, 1024 dims
# EMBEDDING_MODEL=embed-multilingual-v3.0       # Multilingual, 1024 dims
# EMBEDDING_MODEL=embed-multilingual-light-v3.0 # Lighter, 384 dims

# ============================================
# OPTION 5: Jina AI (Cloud - Commercial)
# ============================================
# Best for: Long contexts, late chunking
# Cost: Pay-per-use
EMBEDDING_BINDING=jina
EMBEDDING_MODEL=jina-embeddings-v3
EMBEDDING_DIMENSION=1024
EMBEDDING_API_KEY=your-jina-api-key-here
EMBEDDING_HOST=https://api.jina.ai/v1
EMBEDDING_INPUT_TYPE=retrieval.passage
EMBEDDING_LATE_CHUNKING=false
EMBEDDING_NORMALIZED=true
EMBEDDING_REQUEST_TIMEOUT=30

# Input type options for Jina:
# EMBEDDING_INPUT_TYPE=retrieval.passage    # For documents
# EMBEDDING_INPUT_TYPE=retrieval.query      # For queries
# EMBEDDING_INPUT_TYPE=classification       # For classification
# EMBEDDING_INPUT_TYPE=separation           # For clustering
# EMBEDDING_INPUT_TYPE=text-matching        # For matching

# Jina model options:
# EMBEDDING_MODEL=jina-embeddings-v3  # With late chunking support
# EMBEDDING_MODEL=jina-embeddings-v4  # Latest version

# ============================================
# OPTION 6: Azure OpenAI (Cloud - Enterprise)
# ============================================
# Best for: Enterprise, compliance, regional deployment
# Cost: Pay-per-use
EMBEDDING_BINDING=azure_openai
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSION=3072
EMBEDDING_API_KEY=your-azure-api-key-here
EMBEDDING_HOST=https://your-resource.openai.azure.com
EMBEDDING_REQUEST_TIMEOUT=30

# ============================================
# OPTION 7: HuggingFace Inference API
# ============================================
# Best for: Custom models, flexibility
# Cost: Pay-per-use or free tier
EMBEDDING_BINDING=huggingface
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
EMBEDDING_API_KEY=your-hf-api-key-here
EMBEDDING_HOST=https://api-inference.huggingface.co
EMBEDDING_REQUEST_TIMEOUT=30

# ============================================
# ADVANCED OPTIONS (All Providers)
# ============================================
EMBEDDING_MAX_TOKENS=8192
EMBEDDING_ENCODING_FORMAT=float  # or base64
EMBEDDING_NORMALIZED=true
EMBEDDING_TRUNCATE=true

# ============================================
# API KEY GUIDANCE
# ============================================
# NavyAI uses a single key that DeepTutor can reuse for embeddings, chat,
# images, and video.
NAVY_API_KEY=sk-navy-...

# Non-Navy providers use EMBEDDING_API_KEY with the matching EMBEDDING_BINDING,
# EMBEDDING_MODEL, and EMBEDDING_HOST values above.

# ============================================
# QUICK SETUP GUIDE
# ============================================
#
# FOR LOCAL DEVELOPMENT (FREE):
# 1. Install Ollama: https://ollama.ai
# 2. Download model: ollama pull nomic-embed-text
# 3. Set: EMBEDDING_BINDING=ollama
#
# FOR PRODUCTION (CLOUD):
# 1. Get a NavyAI key.
# 2. Set NAVY_API_KEY.
# 3. Keep EMBEDDING_BINDING=navy and EMBEDDING_MODEL=gemini-embedding-2-preview.
#
# ============================================
